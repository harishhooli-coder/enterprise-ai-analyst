ANTHROPIC_API_KEY=
FRONTIER_PROVIDER=nim
FRONTIER_MODEL=claude-sonnet-4-6
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.3-70b-instruct
BQ_PROJECT_ID=dev-project
BQ_DATASET=analytics
BQ_USE_MOCK=0
# Warehouse: mock | bigquery | postgres (Neon demo)
WAREHOUSE_BACKEND=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
# MCP stdio transport for warehouse tool (1=enabled)
USE_MCP=1
MCP_PYTHON=
# Model tiers: NIM classify (cheap), Claude reason (frontier)
CLASSIFY_PROVIDER=auto
FRONTIER_PROVIDER=anthropic
MAX_BYTES_BILLED=1000000000
LOG_LEVEL=INFO
AGENT_STEP_CAP=10
TOKEN_BUDGET=8000
GROUNDING_RETRIEVAL=auto
EMBEDDING_MATCH_THRESHOLD=0.25
EMBEDDING_AMBIGUITY_MARGIN=0.05
IDENTITY_MODE=stub
BQ_DEV_SERVICE_ACCOUNT=
BQ_IMPERSONATE_TARGET=
WIF_PROVIDER_CONFIG=
CORS_ORIGINS=http://localhost:3000
# Upstash Redis (optional — enables durable audit store when AUDIT_STORE_BACKEND=auto|redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
AUDIT_STORE_BACKEND=auto
AUDIT_REDIS_TTL_SECONDS=604800
